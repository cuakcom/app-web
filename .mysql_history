SELECT 
    table_schema AS 'Base de datos',
    ROUND(SUM(data_length + index_length) / 1024 / 1024, 2) AS 'Tamaño_MB'
FROM information_schema.tables
GROUP BY table_schema
ORDER BY Tamaño_MB DESC;
