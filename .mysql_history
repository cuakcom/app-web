SELECT d.name AS dominio,
       db.name AS base_de_datos,
       u.login AS usuario_mysql
FROM data_bases db
LEFT JOIN db_users u ON db.id = u.db_id
LEFT JOIN domains d ON db.dom_id = d.id
ORDER BY dominio;
